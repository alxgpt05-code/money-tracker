# PostgreSQL connection string for local development.
# For docker-compose local DB keep host=localhost and port=5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/capital_tracker?schema=public"

# HMAC secret for signed auth session cookies.
# Generate a long random value for production.
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional seed controls.
# By default seed does NOT create demo users.
SEED_DEMO_USER="false"
DEMO_USER_EMAIL="demo@money.local"
DEMO_USER_PASSWORD="12345678"
